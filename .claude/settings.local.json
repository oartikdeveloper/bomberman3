{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "git add -A; if ((git status --porcelain) -ne $null) { git commit -m 'Auto-update'; git push } ; exit 0",
            "statusMessage": "GitHub'a gonderiliyor...",
            "async": true
          }
        ]
      }
    ]
  }
}
